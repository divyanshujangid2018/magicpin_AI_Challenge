# Copy to .env and fill in your keys. The bot runs fully without any of these.

# --- LLM polish (optional; deterministic composer is primary) ---
VERA_USE_LLM=1                              # 1 = enable polish, 0 = deterministic only

# Groq (primary LLM — free tier, fast)
GROQ_API_KEY=                               # get from https://console.groq.com
GROQ_MODEL=llama-3.3-70b-versatile         # or llama-3.1-70b-versatile

# Gemini (fallback — optional)
GEMINI_API_KEY=                             # get from https://aistudio.google.com
GEMINI_MODEL=gemini-2.0-flash

VERA_LLM_TIMEOUT=8                          # per-call seconds; falls back on timeout

# --- /v1/metadata identity ---
VERA_TEAM_NAME=Vera Reforged
VERA_TEAM_MEMBER=Divyanshu Jangid
VERA_CONTACT=
